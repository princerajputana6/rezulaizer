# Server Environment Example for Rezulyzer (MERN)

# App
NODE_ENV=development
PORT=8000
CLIENT_URL=http://localhost:3000
MONGO_URI=mongodb://localhost:27017/rezulyzer
JWT_SECRET=supersecret

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
FROM_EMAIL=noreply@yourdomain.com

# Cloudflare Cron Security
CF_CRON_TOKEN=your-strong-random-token

# AI Provider (optional; fallbacks implemented)
AI_PROVIDER=openai
OPENAI_API_KEY=
GROQ_API_KEY=
AI_MODEL=gpt-3.5-turbo
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# AI Matching - Embedding Provider
# Options: 'openai' (recommended, requires OPENAI_API_KEY) or 'simple' (free fallback)
EMBEDDING_PROVIDER=openai

# Worker/Email (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Proctoring config
PROCTOR_WARNING_LIMIT=5

# Cloudinary Configuration (REQUIRED for resume uploads)
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

